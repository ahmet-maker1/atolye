# Atölye.co — server config
# Local geliştirme için: `cp .env.example .env` yap, ardından düzenle.
# Railway'de bu değerleri Project > Variables kısmında set et.

# ─── ZORUNLU ─────────────────────────────────────────────────────

# JWT imzalama anahtarı — EN AZ 32 KARAKTER, rastgele.
# Üretmek için: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=__buraya_64_karakterlik_rastgele_string__

# ─── PRODUCTION (Railway) ────────────────────────────────────────

# 'production' olarak ayarla; loglama ve güvenlik kuralları sıkılaşır.
NODE_ENV=development

# Uygulamanın açık adresi. Railway domain veya kendi domain'in.
# Birden çok varsa virgülle ayır.
# PUBLIC_URL=https://atolye.co
# CORS_ORIGIN=https://atolye.co,https://www.atolye.co

# Railway Volume mount path. Volume eklediysen bu path'i ver.
# Foto ve DB bu klasörün altına yazılır → restart'ta veri kaybolmaz.
# DATA_DIR=/data

# ─── İSTEĞE BAĞLI ────────────────────────────────────────────────

PORT=3001
